# Plain (non encrypted) backup settings
BACKUP_ENABLED=true

# Docker DB credentials (same as docker-compose.yml)
POSTGRES_USER=admin
POSTGRES_PASSWORD=adminpassword
POSTGRES_DB=facture_db

# Keep latest N local backups in ./backups
BACKUP_KEEP_LOCAL=30

# Google Drive upload via rclone (one-time rclone login required)
GDRIVE_UPLOAD=true
GDRIVE_REMOTE=gdrive:
GDRIVE_FOLDER_ID=1QXvBAVteXNnWl-wXuWXuqMNt3K9HIxvg

# Optional dedicated Drive folder for Registres Excel exports only
# Example: https://drive.google.com/drive/folders/<THIS_ID>
REGISTRES_GDRIVE_REMOTE=gdrive:
REGISTRES_GDRIVE_FOLDER_ID=

# Credentials used by automatic Registres XLSX export (API login)
EXPORT_AUTH_USERNAME=admin
EXPORT_AUTH_PASSWORD=admin2025
