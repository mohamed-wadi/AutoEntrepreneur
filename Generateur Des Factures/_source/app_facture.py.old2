def get_client_names():
    return sorted(app_data.get("clients", {}).keys())

e_client = ctk.CTkComboBox(
    client_top, values=get_client_names(),
    height=37, corner_radius=8,
    font=ctk.CTkFont(size=13),
    dropdown_font=ctk.CTkFont(size=13),
)
