entries_d, entries_c, entries_j, entries_p, labels_t = [], [], [], [], []
total_var = ctk.StringVar(value="0 DH")

def get_desig_names():
    return sorted(app_data.get("designations", {}).keys())

def update_totals(*_):
    grand = 0
    for i in range(5):
        val = to_int(calc(entries_j[i].get(), entries_p[i].get()))
        grand += val
        labels_t[i].configure(text=f"{val:,} DH".replace(",", " ") if val else "—")
    total_var.set(f"{grand:,} DH".replace(",", " "))

def make_desig_crud_callbacks(idx):
    """Retourne les callbacks save/delete/select pour la ligne idx."""
    def on_desig_selected(name):
        desigs = app_data.get("designations", {})
        if name in desigs:
            entries_c[idx].delete(0, "end")
            entries_c[idx].insert(0, desigs[name].get("commentaire", ""))

    def save_desig():
        name = entries_d[idx].get().strip()
        if not name:
            show_status(f"⚠  Ligne {idx+1} : entrez une désignation avant de sauvegarder.", "orange")
            return
        app_data.setdefault("designations", {})[name] = {
            "commentaire": entries_c[idx].get().strip()
        }
        save_data(app_data)
        for d_combo in entries_d:
            d_combo.configure(values=get_desig_names())
        show_status(f"✔  Désignation «{name}» sauvegardée.", "green")

    def delete_desig():
        name = entries_d[idx].get().strip()
        if name in app_data.get("designations", {}):
            del app_data["designations"][name]
            save_data(app_data)
            for d_combo in entries_d:
                d_combo.configure(values=get_desig_names())
            entries_d[idx].set("")
            entries_c[idx].delete(0, "end")
            show_status(f"🗑  Désignation «{name}» supprimée.", "gray")
        else:
            show_status(f"⚠  Ligne {idx+1} : désignation introuvable dans la liste.", "orange")

    return on_desig_selected, save_desig, delete_desig

for i in range(5):
    r = i * 2 + 2

    # Col 0 : numéro de ligne
    ctk.CTkLabel(s3, text=str(i+1), font=ctk.CTkFont(size=12),
        text_color="gray", width=24).grid(row=r, column=0, padx=3)

    # Col 1 : Désignation (ComboBox éditable)
    d = ctk.CTkComboBox(s3, values=get_desig_names(), height=34, corner_radius=6,
        font=ctk.CTkFont(size=12), dropdown_font=ctk.CTkFont(size=12))
    d.grid(row=r, column=1, sticky="ew", padx=3)
    d.set("")
    entries_d.append(d)

    # Col 2 : boutons 💾 🗑 inline (créés après callbacks)
    btn_frame = ctk.CTkFrame(s3, fg_color="transparent")
    btn_frame.grid(row=r, column=2, padx=(0, 4))

    # Col 3 : Commentaire
    c = ctk.CTkEntry(s3, placeholder_text="ex: Les 13, 14, 15 avril 2026",
        height=34, corner_radius=6, font=ctk.CTkFont(size=11))
    c.grid(row=r, column=3, sticky="ew", padx=3)
    entries_c.append(c)

    # Col 4 : Jours
    j = ctk.CTkEntry(s3, placeholder_text="0", width=58, height=34,
        corner_radius=6, justify="center")
    j.grid(row=r, column=4, padx=3)
    j.bind("<KeyRelease>", update_totals)
    entries_j.append(j)

    # Col 5 : Prix unitaire
    p = ctk.CTkEntry(s3, placeholder_text="0", width=95, height=34,
        corner_radius=6, justify="center")
    p.grid(row=r, column=5, padx=3)
    p.bind("<KeyRelease>", update_totals)
    entries_p.append(p)

    # Col 6 : Total
    t_lbl = ctk.CTkLabel(s3, text="—",
        font=ctk.CTkFont(size=12, weight="bold"), width=90, anchor="center")
    t_lbl.grid(row=r, column=6, padx=3)
    labels_t.append(t_lbl)

    # Séparateur entre lignes
    if i < 4:
        ctk.CTkFrame(s3, height=1, fg_color="gray20").grid(
            row=r+1, column=0, columnspan=7, sticky="ew", padx=3, pady=3)

# Câbler callbacks CRUD + créer les boutons inline après que toutes les listes sont complètes
for i in range(5):
    on_sel, save_fn, del_fn = make_desig_crud_callbacks(i)
    entries_d[i].configure(command=on_sel)

    # Récupérer le btn_frame de la ligne i (row = i*2+2, col=2)
    # On le retrouve via grid_slaves
    r = i * 2 + 2
    # Chercher le frame dans la colonne 2 de la ligne r
    for widget in s3.grid_slaves(row=r, column=2):
        frame = widget
        ctk.CTkButton(frame, text="💾", width=30, height=32, corner_radius=5,
            font=ctk.CTkFont(size=12), command=save_fn
        ).pack(side="left", padx=(0, 2))
        ctk.CTkButton(frame, text="🗑", width=30, height=32, corner_radius=5,
            fg_color="transparent", border_width=1, border_color="gray50",
            hover_color=("gray85","gray25"), text_color=("gray10","gray90"),
            font=ctk.CTkFont(size=12), command=del_fn
        ).pack(side="left")
        break

ctk.CTkLabel(s3,
    text="  💡 Sélectionnez une désignation → commentaire pré-rempli.  💾 pour sauvegarder,  🗑 pour supprimer.",
    font=ctk.CTkFont(size=11), text_color="gray", wraplength=900, justify="left"
).grid(row=12, column=0, columnspan=7, sticky="w", pady=(8,0))

