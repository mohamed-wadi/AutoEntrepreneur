# ──────────────────────────────────────────────────────────────────────────────
# CHEMINS
# ──────────────────────────────────────────────────────────────────────────────

def get_exe_dir():
    if hasattr(sys, '_MEIPASS'):
        return os.path.dirname(sys.executable)
    return os.path.abspath(".")

def resource_path(relative_path):
    if hasattr(sys, '_MEIPASS'):
        external = os.path.join(os.path.dirname(sys.executable), relative_path)
        if os.path.exists(external):
            return external
        return os.path.join(sys._MEIPASS, relative_path)
    return os.path.join(os.path.abspath("."), relative_path)

def output_path(filename):
    factures_dir = os.path.join(get_exe_dir(), "Factures")
    os.makedirs(factures_dir, exist_ok=True)
    return os.path.join(factures_dir, filename)

def data_path():
    return os.path.join(get_exe_dir(), "app_data.json")

# ──────────────────────────────────────────────────────────────────────────────
# PERSISTANCE JSON
# ──────────────────────────────────────────────────────────────────────────────

def load_data():
    path = data_path()
    if os.path.exists(path):
        try:
            with open(path, "r", encoding="utf-8") as f:
                return json.load(f)
        except Exception:
            pass
    return {
        "last_numero": 0,
        "last_year": datetime.date.today().year,
        "clients": {},
        "designations": {}
    }

def save_data(data):
    try:
        with open(data_path(), "w", encoding="utf-8") as f:
            json.dump(data, f, ensure_ascii=False, indent=2)
    except Exception as e:
        print(f"Erreur sauvegarde : {e}")

def get_next_numero(data):
    today_year = datetime.date.today().year
    if data.get("last_year") != today_year:
        return 1, today_year
    return data.get("last_numero", 0) + 1, today_year

def parse_numero(num_str):
    try:
        parts = num_str.strip().split("/")
        if len(parts) == 2:
            return int(parts[0]), int(parts[1])
    except Exception:
        pass
    return None, None

# ──────────────────────────────────────────────────────────────────────────────
# REMPLACEMENT WORD — préserve la mise en forme run par run
# ──────────────────────────────────────────────────────────────────────────────

def replace_in_para(para, replacements):
    """
    Remplace les placeholders en respectant les runs individuels.
    Stratégie :
      1. Tentative run-par-run (préserve bold/italic/taille/police)
      2. Fallback : reconstruction du texte complet si un placeholder
         est cassé entre plusieurs runs (perd le formatage du premier run seulement)
    """
    # Étape 1 : remplacement dans chaque run indépendamment
    for run in para.runs:
        for k, v in replacements.items():
            if k in run.text:
                run.text = run.text.replace(k, v)

    # Étape 2 : fallback pour placeholders cassés entre runs
    full = "".join(r.text for r in para.runs)
    needs_fallback = any(k in full for k in replacements)
    if needs_fallback:
        new_full = full
        for k, v in replacements.items():
            new_full = new_full.replace(k, v)
        if new_full != full:
            for r in para.runs:
                r.text = ""
            if para.runs:
                para.runs[0].text = new_full

def remplacer(doc, replacements):
    for p in doc.paragraphs:
        replace_in_para(p, replacements)
    for table in doc.tables:
        for row in table.rows:
            for cell in row.cells:
                for p in cell.paragraphs:
                    replace_in_para(p, replacements)

# ──────────────────────────────────────────────────────────────────────────────
# UTILITAIRES
# ──────────────────────────────────────────────────────────────────────────────

def calc(j, p):
    try:
        return str(int(j) * int(p)) if j and p else ""
    except Exception:
        return ""

def to_int(x):
    try:
        return int(x) if x else 0
    except Exception:
        return 0

def bullet(text):
    return f"• {text.strip()}" if text.strip() else ""

# ──────────────────────────────────────────────────────────────────────────────
# CALENDRIER POPUP
# ──────────────────────────────────────────────────────────────────────────────

MONTHS_FR = ["Janvier", "Février", "Mars", "Avril", "Mai", "Juin",
             "Juillet", "Août", "Septembre", "Octobre", "Novembre", "Décembre"]
DAYS_FR   = ["Lu", "Ma", "Me", "Je", "Ve", "Sa", "Di"]

def open_calendar(parent, entry_widget):
    today = datetime.date.today()
    state = {"year": today.year, "month": today.month}

    top = ctk.CTkToplevel(parent)
    top.title("Choisir une date")
    top.geometry("310x295")
    top.resizable(False, False)
    top.grab_set(); top.focus_set()

    nav = ctk.CTkFrame(top, fg_color="transparent")
    nav.pack(fill="x", padx=12, pady=(12, 6))
    btn_prev = ctk.CTkButton(nav, text="◀", width=34, height=30, corner_radius=6)
    btn_prev.pack(side="left")
    month_lbl = ctk.CTkLabel(nav, text="", font=ctk.CTkFont(size=14, weight="bold"), width=200)
    month_lbl.pack(side="left", expand=True)
    btn_next = ctk.CTkButton(nav, text="▶", width=34, height=30, corner_radius=6)
    btn_next.pack(side="right")

    grid = ctk.CTkFrame(top, fg_color="transparent")
    grid.pack(fill="both", expand=True, padx=12, pady=(0, 12))

    def render():
        for w in grid.winfo_children(): w.destroy()
        month_lbl.configure(text=f"{MONTHS_FR[state['month']-1]}  {state['year']}")
        for col, d in enumerate(DAYS_FR):
            ctk.CTkLabel(grid, text=d, font=ctk.CTkFont(size=11, weight="bold"),
                         text_color="gray", width=36, anchor="center"
                         ).grid(row=0, column=col, padx=1, pady=(0, 4))
        for week_row, week in enumerate(calendar.monthcalendar(state["year"], state["month"])):
            for col, day in enumerate(week):
                if day == 0:
                    ctk.CTkLabel(grid, text="", width=36).grid(row=week_row+1, column=col, padx=1, pady=1)
                    continue
                is_today = (day == today.day and state["month"] == today.month and state["year"] == today.year)
                ctk.CTkButton(
                    grid, text=str(day), width=36, height=30, corner_radius=6,
                    font=ctk.CTkFont(size=12, weight="bold" if is_today else "normal"),
                    fg_color=("#1f538d","#1f538d") if is_today else "transparent",
                    text_color=("white" if is_today else ("gray10","gray90")),
                    hover_color=("gray80","gray30"),
                    command=lambda d=day: pick(d)
                ).grid(row=week_row+1, column=col, padx=1, pady=1)

    def pick(day):
        entry_widget.delete(0, "end")
        entry_widget.insert(0, f"{day:02d}/{state['month']:02d}/{state['year']}")
        top.destroy()

    def prev_month():
        state["month"] = 12 if state["month"] == 1 else state["month"] - 1
        if state["month"] == 12: state["year"] -= 1
        render()

    def next_month():
        state["month"] = 1 if state["month"] == 12 else state["month"] + 1
        if state["month"] == 1: state["year"] += 1
        render()

    btn_prev.configure(command=prev_month)
    btn_next.configure(command=next_month)
    render()

