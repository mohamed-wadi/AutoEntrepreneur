# ──────────────────────────────────────────────────────────────────────────────
# CHEMINS
# ──────────────────────────────────────────────────────────────────────────────

def get_exe_dir():
    if hasattr(sys, '_MEIPASS'):
        return os.path.dirname(sys.executable)
    return os.path.abspath(".")

def resource_path(relative_path):
    if hasattr(sys, '_MEIPASS'):
        external = os.path.join(os.path.dirname(sys.executable), relative_path)
        if os.path.exists(external):
            return external
        return os.path.join(sys._MEIPASS, relative_path)
    return os.path.join(os.path.abspath("."), relative_path)

def factures_dir():
    d = os.path.join(get_exe_dir(), "Factures")
    os.makedirs(d, exist_ok=True)
    return d

def output_path(filename):
    return os.path.join(factures_dir(), filename)

def data_path():
    return os.path.join(get_exe_dir(), "app_data.json")

# ──────────────────────────────────────────────────────────────────────────────
# AUTO-NUMÉRO : scan du dossier Factures/ — plus de JSON pour last_numero
# Formats reconnus :
#   "Facture numéro 34-2026.docx"
#   "Facture_34_2026.docx"  (ancien format)
# ──────────────────────────────────────────────────────────────────────────────

_FNAME_PAT = re.compile(r'[Ff]acture[^\d]*(\d+)[-_](\d{4}).*\.docx$', re.IGNORECASE)

def scan_last_numero():
    """Retourne (max_num, year) pour l'année courante, (0, current_year) si vide."""
    today_year = datetime.date.today().year
    max_num = 0
    try:
        for fname in os.listdir(factures_dir()):
            m = _FNAME_PAT.search(fname)
            if m:
                num  = int(m.group(1))
                year = int(m.group(2))
                if year == today_year and num > max_num:
                    max_num = num
    except Exception:
        pass
    return max_num, today_year

def get_next_numero():
    last_num, year = scan_last_numero()
    return last_num + 1, year

# ──────────────────────────────────────────────────────────────────────────────
# PERSISTANCE JSON  (clients + désignations uniquement)
# ──────────────────────────────────────────────────────────────────────────────

def load_data():
    path = data_path()
    if os.path.exists(path):
        try:
            with open(path, "r", encoding="utf-8") as f:
                return json.load(f)
        except Exception:
            pass
    return {"clients": {}, "designations": {}}

def save_data(data):
    try:
        with open(data_path(), "w", encoding="utf-8") as f:
            json.dump(data, f, ensure_ascii=False, indent=2)
    except Exception as e:
        print(f"Erreur sauvegarde : {e}")

def parse_numero(num_str):
    try:
        parts = num_str.strip().split("/")
        if len(parts) == 2:
            return int(parts[0]), int(parts[1])
    except Exception:
        pass
    return None, None

# ──────────────────────────────────────────────────────────────────────────────
# REMPLACEMENT WORD — run par run, force Bold Arial 10pt sur commentaires
# ──────────────────────────────────────────────────────────────────────────────

def _apply_commentaire_style(run_elem):
    """
    Force sur le run XML : Bold + Arial + 10pt (= 20 demi-points).
    Crée ou met à jour le bloc <w:rPr>.
    """
    # Trouver ou créer <w:rPr>
    rpr = run_elem.find(qn('w:rPr'))
    if rpr is None:
        rpr = OxmlElement('w:rPr')
        run_elem.insert(0, rpr)

    # --- Bold ---
    if rpr.find(qn('w:b')) is None:
        rpr.append(OxmlElement('w:b'))
    if rpr.find(qn('w:bCs')) is None:
        rpr.append(OxmlElement('w:bCs'))

    # --- Taille 10pt = 20 demi-points ---
    for tag in (qn('w:sz'), qn('w:szCs')):
        el = rpr.find(tag)
        if el is None:
            el = OxmlElement(tag.split('}')[1] if '}' in tag else tag)
            # OxmlElement prend un nom local sans namespace
            el = OxmlElement('w:sz' if tag == qn('w:sz') else 'w:szCs')
            rpr.append(el)
        el.set(qn('w:val'), '20')

    # --- Police Arial ---
    rfonts = rpr.find(qn('w:rFonts'))
    if rfonts is None:
        rfonts = OxmlElement('w:rFonts')
        rpr.append(rfonts)
    for attr in (qn('w:ascii'), qn('w:hAnsi'), qn('w:cs')):
        rfonts.set(attr, 'Arial')


def replace_in_para(para, replacements, commentaire_keys=None):
    """
    Remplace les placeholders en préservant la mise en forme run par run.
    Pour les clés dans commentaire_keys → applique Bold Arial 10pt après remplacement.
    Fallback pour les placeholders cassés entre plusieurs runs.
    """
    if commentaire_keys is None:
        commentaire_keys = set()

    # Étape 1 : remplacement run par run
    for run in para.runs:
        for k, v in replacements.items():
            if k in run.text:
                run.text = run.text.replace(k, v)
                if k in commentaire_keys:
                    _apply_commentaire_style(run._r)

    # Étape 2 : fallback — placeholder cassé entre plusieurs runs
    full = "".join(r.text for r in para.runs)
    if any(k in full for k in replacements):
        new_full = full
        touched_commentaire = False
        for k, v in replacements.items():
            if k in full:
                new_full = new_full.replace(k, v)
                if k in commentaire_keys and v:
                    touched_commentaire = True
        if new_full != full:
            for r in para.runs:
                r.text = ""
            if para.runs:
                para.runs[0].text = new_full
                if touched_commentaire:
                    _apply_commentaire_style(para.runs[0]._r)


def remplacer(doc, replacements, commentaire_keys=None):
    for p in doc.paragraphs:
        replace_in_para(p, replacements, commentaire_keys)
    for table in doc.tables:
        for row in table.rows:
            for cell in row.cells:
                for p in cell.paragraphs:
                    replace_in_para(p, replacements, commentaire_keys)

# ──────────────────────────────────────────────────────────────────────────────
# UTILITAIRES
# ──────────────────────────────────────────────────────────────────────────────

def calc(j, p):
    try:
        return str(int(j) * int(p)) if j and p else ""
    except Exception:
        return ""

def to_int(x):
    try:
        return int(x) if x else 0
    except Exception:
        return 0

def bullet(text):
    return f"• {text.strip()}" if text.strip() else ""

# ──────────────────────────────────────────────────────────────────────────────
# CALENDRIER POPUP
# ──────────────────────────────────────────────────────────────────────────────

MONTHS_FR = ["Janvier", "Février", "Mars", "Avril", "Mai", "Juin",
             "Juillet", "Août", "Septembre", "Octobre", "Novembre", "Décembre"]
DAYS_FR   = ["Lu", "Ma", "Me", "Je", "Ve", "Sa", "Di"]

def open_calendar(parent, entry_widget):
    today = datetime.date.today()
    state = {"year": today.year, "month": today.month}

    top = ctk.CTkToplevel(parent)
    top.title("Choisir une date")
    top.geometry("310x295")
    top.resizable(False, False)
    top.grab_set(); top.focus_set()

    nav = ctk.CTkFrame(top, fg_color="transparent")
    nav.pack(fill="x", padx=12, pady=(12, 6))
    btn_prev = ctk.CTkButton(nav, text="◀", width=34, height=30, corner_radius=6)
    btn_prev.pack(side="left")
    month_lbl = ctk.CTkLabel(nav, text="", font=ctk.CTkFont(size=14, weight="bold"), width=200)
    month_lbl.pack(side="left", expand=True)
    btn_next = ctk.CTkButton(nav, text="▶", width=34, height=30, corner_radius=6)
    btn_next.pack(side="right")

    grid_frame = ctk.CTkFrame(top, fg_color="transparent")
    grid_frame.pack(fill="both", expand=True, padx=12, pady=(0, 12))

    def render():
        for w in grid_frame.winfo_children(): w.destroy()
        month_lbl.configure(text=f"{MONTHS_FR[state['month']-1]}  {state['year']}")
        for col, d in enumerate(DAYS_FR):
            ctk.CTkLabel(grid_frame, text=d, font=ctk.CTkFont(size=11, weight="bold"),
                         text_color="gray", width=36, anchor="center"
                         ).grid(row=0, column=col, padx=1, pady=(0, 4))
        for week_row, week in enumerate(calendar.monthcalendar(state["year"], state["month"])):
            for col, day in enumerate(week):
                if day == 0:
                    ctk.CTkLabel(grid_frame, text="", width=36).grid(row=week_row+1, column=col, padx=1, pady=1)
                    continue
                is_today = (day == today.day and state["month"] == today.month and state["year"] == today.year)
                ctk.CTkButton(
                    grid_frame, text=str(day), width=36, height=30, corner_radius=6,
                    font=ctk.CTkFont(size=12, weight="bold" if is_today else "normal"),
                    fg_color=("#1f538d","#1f538d") if is_today else "transparent",
                    text_color=("white" if is_today else ("gray10","gray90")),
                    hover_color=("gray80","gray30"),
                    command=lambda d=day: pick(d)
                ).grid(row=week_row+1, column=col, padx=1, pady=1)

    def pick(day):
        entry_widget.delete(0, "end")
        entry_widget.insert(0, f"{day:02d}/{state['month']:02d}/{state['year']}")
        top.destroy()

    def prev_month():
        state["month"] = 12 if state["month"] == 1 else state["month"] - 1
        if state["month"] == 12: state["year"] -= 1
        render()

    def next_month():
        state["month"] = 1 if state["month"] == 12 else state["month"] + 1
        if state["month"] == 1: state["year"] += 1
        render()

    btn_prev.configure(command=prev_month)
    btn_next.configure(command=next_month)
    render()

