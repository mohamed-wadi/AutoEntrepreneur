entries_d, entries_c, entries_j, entries_p, labels_t = [], [], [], [], []
total_var = ctk.StringVar(value="0 DH")

def get_desig_names():
    return sorted(app_data.get("designations", {}).keys())

def update_totals(*_):
    grand = 0
    for i in range(5):
        val = to_int(calc(entries_j[i].get(), entries_p[i].get()))
        grand += val
        labels_t[i].configure(text=f"{val:,} DH".replace(",", " ") if val else "—")
    total_var.set(f"{grand:,} DH".replace(",", " "))

def make_desig_crud_callbacks(idx):
    def on_desig_selected(name):
        desigs = app_data.get("designations", {})
        if name in desigs:
            entries_c[idx].delete(0, "end")
            entries_c[idx].insert(0, desigs[name].get("commentaire", ""))

    def save_desig():
        name = entries_d[idx].get().strip()
        if not name:
            show_status(f"⚠  Ligne {idx+1} : entrez une désignation avant de sauvegarder.", "orange")
            return
        app_data.setdefault("designations", {})[name] = {
            "commentaire": entries_c[idx].get().strip()
        }
        save_data(app_data)
        for d_combo in entries_d:
            d_combo.configure(values=get_desig_names())
        show_status(f"✔  Désignation «{name}» sauvegardée.", "green")

    def delete_desig():
        name = entries_d[idx].get().strip()
        if name in app_data.get("designations", {}):
            del app_data["designations"][name]
            save_data(app_data)
            for d_combo in entries_d:
                d_combo.configure(values=get_desig_names())
            entries_d[idx].set("")
            entries_c[idx].delete(0, "end")
            show_status(f"🗑  Désignation «{name}» supprimée.", "gray")
        else:
            show_status(f"⚠  Ligne {idx+1} : désignation introuvable dans la liste.", "orange")

    return on_desig_selected, save_desig, delete_desig

for i in range(5):
    r = i * 2 + 2

    ctk.CTkLabel(s3, text=str(i+1), font=ctk.CTkFont(size=12),
        text_color="gray", width=24).grid(row=r, column=0, padx=3)

    d = ctk.CTkComboBox(s3, values=get_desig_names(), height=34, corner_radius=6,
        font=ctk.CTkFont(size=12), dropdown_font=ctk.CTkFont(size=12))
    d.grid(row=r, column=1, sticky="ew", padx=3)
    d.set("")
    entries_d.append(d)

    btn_frame = ctk.CTkFrame(s3, fg_color="transparent")
    btn_frame.grid(row=r, column=2, padx=(0, 4))

    c = ctk.CTkEntry(s3, placeholder_text="ex: Les 13, 14, 15 avril 2026",
        height=34, corner_radius=6, font=ctk.CTkFont(size=11))
    c.grid(row=r, column=3, sticky="ew", padx=3)
    entries_c.append(c)

    j = ctk.CTkEntry(s3, placeholder_text="0", width=58, height=34,
        corner_radius=6, justify="center")
    j.grid(row=r, column=4, padx=3)
    j.bind("<KeyRelease>", update_totals)
    entries_j.append(j)

    p = ctk.CTkEntry(s3, placeholder_text="0", width=95, height=34,
        corner_radius=6, justify="center")
    p.grid(row=r, column=5, padx=3)
    p.bind("<KeyRelease>", update_totals)
    entries_p.append(p)

    t_lbl = ctk.CTkLabel(s3, text="—",
        font=ctk.CTkFont(size=12, weight="bold"), width=90, anchor="center")
    t_lbl.grid(row=r, column=6, padx=3)
    labels_t.append(t_lbl)

    if i < 4:
        ctk.CTkFrame(s3, height=1, fg_color="gray20").grid(
            row=r+1, column=0, columnspan=7, sticky="ew", padx=3, pady=3)

# Câbler CRUD + boutons inline
for i in range(5):
    on_sel, save_fn, del_fn = make_desig_crud_callbacks(i)
    entries_d[i].configure(command=on_sel)
    r = i * 2 + 2
    for widget in s3.grid_slaves(row=r, column=2):
        ctk.CTkButton(widget, text="💾", width=30, height=32, corner_radius=5,
            font=ctk.CTkFont(size=12), command=save_fn
        ).pack(side="left", padx=(0, 2))
        ctk.CTkButton(widget, text="🗑", width=30, height=32, corner_radius=5,
            fg_color="transparent", border_width=1, border_color="gray50",
            hover_color=("gray85","gray25"), text_color=("gray10","gray90"),
            font=ctk.CTkFont(size=12), command=del_fn
        ).pack(side="left")
        break

ctk.CTkLabel(s3,
    text="  💡 Sélectionnez une désignation → commentaire pré-rempli.  💾 sauvegarder  🗑 supprimer.",
    font=ctk.CTkFont(size=11), text_color="gray", wraplength=900, justify="left"
).grid(row=12, column=0, columnspan=7, sticky="w", pady=(8,0))

# ── Total général ────────────────────────────────────────────────────────────
tf = ctk.CTkFrame(scroll, corner_radius=12)
tf.pack(fill="x", pady=(0,14))
ctk.CTkLabel(tf, text="Montant total HT", font=ctk.CTkFont(size=13),
    text_color="gray").pack(anchor="e", padx=22, pady=(13,0))
ctk.CTkLabel(tf, textvariable=total_var,
    font=ctk.CTkFont(size=30, weight="bold")).pack(anchor="e", padx=22, pady=(2,13))

# ── Status ───────────────────────────────────────────────────────────────────
status_label = ctk.CTkLabel(scroll, text="",
    font=ctk.CTkFont(size=13, weight="bold"), wraplength=900, justify="left")
status_label.pack(fill="x", pady=(0,4))

# ──────────────────────────────────────────────────────────────────────────────
# GÉNÉRATION
# ──────────────────────────────────────────────────────────────────────────────

def generer():
    status_label.configure(text="")
    num_str = e_num.get().strip()
    if not num_str:
        show_status("⚠  Veuillez renseigner le numéro de facture.", "orange"); return
    if not e_client.get().strip():
        show_status("⚠  Veuillez renseigner le nom du client.", "orange"); return

    modele = resource_path("modele_facture.docx")
    if not os.path.exists(modele):
        show_status(f"❌  modele_facture.docx introuvable !\n    {modele}", "red"); return

    try:
        doc    = Document(modele)
        totaux = [calc(entries_j[i].get(), entries_p[i].get()) for i in range(5)]
        total  = sum(to_int(t) for t in totaux)

        # Clés commentaire → Bold Arial 10pt forcé dans le docx
        commentaire_keys = {f"{{{{commentaire_{i+1}}}}}" for i in range(5)}

        replacements = {
            "{{facture_numero}}":  num_str,
            "{{date_facture}}":    e_date.get().strip(),
            "{{client_nom}}":      e_client.get().strip(),
            "{{client_adresse}}":  e_adresse.get().strip(),
            "{{client_ice}}":      e_ice.get().strip(),
            **{f"{{{{designation_{i+1}}}}}": bullet(entries_d[i].get()) for i in range(5)},
            **{f"{{{{commentaire_{i+1}}}}}": entries_c[i].get().strip()  for i in range(5)},
            **{f"{{{{jours_{i+1}}}}}":       entries_j[i].get()          for i in range(5)},
            **{f"{{{{pu_{i+1}}}}}":          entries_p[i].get()          for i in range(5)},
            **{f"{{{{total_{i+1}}}}}":       totaux[i]                   for i in range(5)},
            "{{montant_total}}":   str(total),
            "{{montant_lettres}}": num2words(total, lang='fr').capitalize() + " dirhams",
            "{{rib}}":             "007780000401230040249794",
        }

        remplacer(doc, replacements, commentaire_keys)

        # ── Nom du fichier : "Facture numéro 35-2026.docx"
        num_int, year_int = parse_numero(num_str)
        if num_int is not None:
            fname = f"Facture numéro {num_int}-{year_int}.docx"
        else:
            safe = num_str.replace("/","_").replace("\\","_")
            fname = f"Facture_{safe}.docx"

        dest = output_path(fname)
        doc.save(dest)

        if sys.platform == "win32":    os.startfile(dest)
        elif sys.platform == "darwin": os.system(f'open "{dest}"')
        else:                          os.system(f'xdg-open "{dest}"')

        show_status(f"✔  Facture générée → {dest}", "green")

        # Rafraîchir le champ numéro (le nouveau fichier est maintenant dans Factures/)
        n, y = get_next_numero()
        e_num.delete(0, "end")
        e_num.insert(0, f"{n}/{y}")

    except Exception as e:
        show_status(f"❌  Erreur : {e}", "red")
        import traceback; traceback.print_exc()

ctk.CTkButton(scroll, text="  Générer la facture (.docx)",
    height=50, corner_radius=10,
    font=ctk.CTkFont(size=15, weight="bold"),
    command=generer).pack(fill="x", pady=(0,28))

app.mainloop()