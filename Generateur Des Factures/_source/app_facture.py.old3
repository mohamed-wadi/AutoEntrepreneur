status_label = None  # défini plus bas

def show_status(msg, color="green"):
    if status_label:
        status_label.configure(text=msg, text_color=color)

def make_section(parent, title):
    frame = ctk.CTkFrame(parent, corner_radius=12)
    frame.pack(fill="x", pady=(0, 14))
    ctk.CTkLabel(frame, text=f"  {title}",
                 font=ctk.CTkFont(size=11, weight="bold"),
                 text_color="gray", anchor="w"
                 ).pack(fill="x", padx=16, pady=(13, 4))
    ctk.CTkFrame(frame, height=1, fg_color="gray30").pack(fill="x", padx=16, pady=(0, 12))
    inner = ctk.CTkFrame(frame, fg_color="transparent")
    inner.pack(fill="x", padx=16, pady=(0, 16))
    return inner

def small_btn(parent, text, command, color=None):
    return ctk.CTkButton(
        parent, text=text, width=37, height=34, corner_radius=6,
        font=ctk.CTkFont(size=14),
        fg_color=color if color else "transparent",
        border_width=0 if color else 1,
        border_color="gray50",
        hover_color=("gray85","gray25"),
        text_color=("gray10","gray90") if not color else "white",
        command=command
    )

