        height=34, corner_radius=6, font=ctk.CTkFont(size=11))
    c.grid(row=r, column=2, sticky="ew", padx=3)
    entries_c.append(c)

    # Jours
    j = ctk.CTkEntry(s3, placeholder_text="0", width=60, height=34,
        corner_radius=6, justify="center")
    j.grid(row=r, column=3, padx=3)
    j.bind("<KeyRelease>", update_totals)
    entries_j.append(j)

    # Prix unitaire
    p = ctk.CTkEntry(s3, placeholder_text="0", width=100, height=34,
        corner_radius=6, justify="center")
    p.grid(row=r, column=4, padx=3)
    p.bind("<KeyRelease>", update_totals)
    entries_p.append(p)

    # Total
    t_lbl = ctk.CTkLabel(s3, text="—",
        font=ctk.CTkFont(size=12, weight="bold"), width=95, anchor="center")
    t_lbl.grid(row=r, column=5, padx=3)
    labels_t.append(t_lbl)

    if i < 4:
        ctk.CTkFrame(s3, height=1, fg_color="gray20").grid(
            row=r+1, column=0, columnspan=6, sticky="ew", padx=3, pady=4)

# Câbler les callbacks CRUD après que tous les widgets sont créés
for i in range(5):
    on_sel, save_fn, del_fn = make_desig_crud_callbacks(i)
    entries_d[i].configure(command=on_sel)
    # Boutons 💾 🗑 sous le tableau
# On crée une ligne de boutons par row dans une frame séparée
