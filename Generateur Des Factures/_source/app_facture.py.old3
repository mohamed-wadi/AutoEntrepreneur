def on_client_selected(name):
    cl = app_data.get("clients", {})
    if name in cl:
        e_ice.delete(0,"end"); e_ice.insert(0, cl[name].get("ice",""))
        e_adresse.delete(0,"end"); e_adresse.insert(0, cl[name].get("adresse",""))

e_client.configure(command=on_client_selected)

def save_client():
    name = e_client.get().strip()
    if not name:
        show_status("⚠  Entrez un nom de client avant de sauvegarder.", "orange"); return
    app_data.setdefault("clients", {})[name] = {
        "ice": e_ice.get().strip(), "adresse": e_adresse.get().strip()
    }
    save_data(app_data)
    e_client.configure(values=get_client_names())
    show_status(f"✔  Client «{name}» sauvegardé.", "green")

def delete_client():
    name = e_client.get().strip()
    if name in app_data.get("clients", {}):
        del app_data["clients"][name]
        save_data(app_data)
        e_client.configure(values=get_client_names())
        e_client.set(""); e_ice.delete(0,"end"); e_adresse.delete(0,"end")
        show_status(f"🗑  Client «{name}» supprimé.", "gray")
    else:
        show_status("⚠  Ce client n'est pas dans la liste.", "orange")

ctk.CTkButton(ct, text="💾 Sauvegarder", width=140, height=37, corner_radius=8,
