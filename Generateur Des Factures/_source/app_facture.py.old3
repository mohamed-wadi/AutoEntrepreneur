tf = ctk.CTkFrame(scroll, corner_radius=12)
tf.pack(fill="x", pady=(0,14))
ctk.CTkLabel(tf, text="Montant total HT", font=ctk.CTkFont(size=13),
    text_color="gray").pack(anchor="e", padx=22, pady=(13,0))
ctk.CTkLabel(tf, textvariable=total_var,
    font=ctk.CTkFont(size=30, weight="bold")).pack(anchor="e", padx=22, pady=(2,13))

# ── Status ───────────────────────────────────────────────────────────────────
status_label = ctk.CTkLabel(scroll, text="",
    font=ctk.CTkFont(size=13, weight="bold"), wraplength=880, justify="left")
status_label.pack(fill="x", pady=(0,4))

# ──────────────────────────────────────────────────────────────────────────────
# GÉNÉRATION
# ──────────────────────────────────────────────────────────────────────────────

def generer():
    status_label.configure(text="")
    num_str = e_num.get().strip()
    if not num_str:
        show_status("⚠  Veuillez renseigner le numéro de facture.", "orange"); return
    if not e_client.get().strip():
        show_status("⚠  Veuillez renseigner le nom du client.", "orange"); return

    modele = resource_path("modele_facture.docx")
    if not os.path.exists(modele):
        show_status(f"❌  modele_facture.docx introuvable !\n    {modele}", "red"); return

    try:
        doc    = Document(modele)
        totaux = [calc(entries_j[i].get(), entries_p[i].get()) for i in range(5)]
        total  = sum(to_int(t) for t in totaux)

        data = {
            "{{facture_numero}}":  num_str,
            "{{date_facture}}":    e_date.get().strip(),
            "{{client_nom}}":      e_client.get().strip(),
            "{{client_adresse}}":  e_adresse.get().strip(),
            "{{client_ice}}":      e_ice.get().strip(),
            # Désignations (bullet) + commentaires (Bold 10pt dans le run séparé du template)
            **{f"{{{{designation_{i+1}}}}}": bullet(entries_d[i].get()) for i in range(5)},
            **{f"{{{{commentaire_{i+1}}}}}": entries_c[i].get().strip()  for i in range(5)},
            **{f"{{{{jours_{i+1}}}}}":       entries_j[i].get()          for i in range(5)},
            **{f"{{{{pu_{i+1}}}}}":          entries_p[i].get()          for i in range(5)},
            **{f"{{{{total_{i+1}}}}}":       totaux[i]                   for i in range(5)},
            "{{montant_total}}":   str(total),
            "{{montant_lettres}}": num2words(total, lang='fr').capitalize() + " dirhams",
            "{{rib}}":             "007780000401230040249794",
        }

        remplacer(doc, data)

        safe = num_str.replace("/","_").replace("\\","_")
        dest = output_path(f"Facture_{safe}.docx")
        doc.save(dest)

        # Sauvegarder le numéro pour le prochain auto-incrément
        num_int, year_int = parse_numero(num_str)
        if num_int is not None:
            app_data["last_numero"] = num_int
            app_data["last_year"]   = year_int
            save_data(app_data)
            global auto_num_str, next_num, next_year
            next_num, next_year = get_next_numero(app_data)
            auto_num_str = f"{next_num}/{next_year}"

        if sys.platform == "win32":  os.startfile(dest)
        elif sys.platform == "darwin": os.system(f'open "{dest}"')
        else: os.system(f'xdg-open "{dest}"')

        show_status(f"✔  Facture générée → {dest}", "green")

    except Exception as e:
        show_status(f"❌  Erreur : {e}", "red")

ctk.CTkButton(scroll, text="  Générer la facture (.docx)",
    height=50, corner_radius=10,
    font=ctk.CTkFont(size=15, weight="bold"),
    command=generer).pack(fill="x", pady=(0,28))

app.mainloop()